# .env.example — 環境變數範本（不含真實值，僅作參考）
# 複製為 .env 後填入真實值，.env 已在 .gitignore 中排除

# ── 必填（Railway 部署必須設定）──────────────────────────────────

# 寫入 API 的保護 token（建議使用 32 字元以上的隨機字串）
ADMIN_TOKEN=your-random-secret-token-here

# Railway 自動提供，本機連 PG 時才需手動設定
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── 選填 ────────────────────────────────────────────────────────

# 限定允許的跨域來源（逗號分隔多個）
# 未設定 → 允許所有 origin（僅建議開發環境）
# CORS_ORIGIN=https://your-app.railway.app

# 排除舊版週報格式的標記（預設 _v7）
# REPORT_EXCLUDE_TAG=_v7

# ── Notion 同步（scripts/save-notion.js 使用）────────────────────

# Notion Integration Token（從 https://www.notion.so/my-integrations 取得）
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 目標資料庫 ID（從 Notion 資料庫 URL 取得）
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 目標頁面 ID（選填，部分腳本使用）
# NOTION_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
